{
  "name": "portfolioweb",
  "version": "1.0.0",
  "description": "Minimalist portfolio website with React, Vite, and Convex",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace @portfolio/web run dev",
    "build": "npm --workspace @portfolio/web run build",
    "preview": "npm --workspace @portfolio/web run preview",
    "lint": "npm --workspaces run lint --if-present",
    "type-check": "npm --workspaces run type-check --if-present"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
