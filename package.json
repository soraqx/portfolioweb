{
  "name": "portfolioweb",
  "version": "1.0.0",
  "description": "Minimalist portfolio website with React, Vite, and Convex",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @portfolio/web dev",
